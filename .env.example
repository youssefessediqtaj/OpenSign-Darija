# Core public application
APP_ENV=development
APP_NAME=OpenSigne Darija
APP_VERSION=1.0.0
NGINX_HOST_PORT=8081

# The Docker web build must use the same-origin Nginx gateway. For a standalone Vite
# development server only, override this with http://localhost:8000.
VITE_API_BASE_URL=
VITE_MEDIAPIPE_MODEL_PATH=/models/holistic_landmarker.task
VITE_MEDIAPIPE_WASM_PATH=/mediapipe/wasm
MEDIAPIPE_HOLISTIC_MODEL_PATH=ml/assets/mediapipe/holistic_landmarker.task
VITE_CAMERA_DEFAULT_WIDTH=1280
VITE_CAMERA_DEFAULT_HEIGHT=720
VITE_CAMERA_DEFAULT_FPS=30
VITE_LANDMARK_TARGET_FRAMES=60

# Strict anonymous landmark-only recognition
INFERENCE_SERVICE_URL=http://inference:8001
INFERENCE_TIMEOUT_SECONDS=3
INFERENCE_MODE=real
FEATURE_SCHEMA_VERSION=OPEN_SIGNE_LANDMARK_SCHEMA_V1
RECOGNITION_MAX_FRAMES=60
RECOGNITION_MAX_PAYLOAD_BYTES=1500000
RECOGNITION_MIN_DURATION_MS=500
RECOGNITION_MAX_DURATION_MS=8000
RECOGNITION_RATE_LIMIT=30
RECOGNITION_MIN_USABLE_FRAMES=12
RECOGNITION_MIN_HAND_RATIO=0.35
RECOGNITION_MAX_MISSING_FRAME_RATIO=0.50
RECOGNITION_MIN_DYNAMIC_MOVEMENT=0.04

# Local production-oriented package; real mode fails closed if any contract is invalid.
MODEL_NAME=mosl-isolated-sign-v1
MODEL_VERSION=1.0.0
MODEL_PATH=/workspace/artifacts/models/mosl-isolated-sign-v1/model.onnx
LABELS_PATH=/workspace/artifacts/models/mosl-isolated-sign-v1/labels.json
SUPPORTED_SIGNS_PATH=/workspace/artifacts/models/mosl-isolated-sign-v1/supported-signs.json
THRESHOLDS_PATH=/workspace/artifacts/models/mosl-isolated-sign-v1/confidence-calibration.json
CALIBRATION_PATH=/workspace/artifacts/models/mosl-isolated-sign-v1/confidence-calibration.json
MODEL_CHECKSUM_REQUIRED=true
MODEL_MAX_SIZE_BYTES=50000000
MODEL_WARMUP_ENABLED=true
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider
INFERENCE_MAX_BATCH_SIZE=1
INFERENCE_MAX_CONCURRENT_REQUESTS=4

# Offline Arabic speech; no remote model or external speech API is used.
SPEECH_SERVICE_URL=http://speech:8010
SPEECH_MODE=local
SPEECH_PROVIDER=local_darija
SPEECH_MODEL_VERSION=opensign-system-arabic-v1
SPEECH_DEFAULT_VOICE_ID=darija-default
SPEECH_FALLBACK_PROVIDER=local_arabic_fallback
SPEECH_GENERATION_TIMEOUT_SECONDS=20
SPEECH_MAX_TEXT_LENGTH=500
SPEECH_MAX_SENTENCES=5
SPEECH_MAX_CONCURRENT_GENERATIONS=2
SPEECH_AUDIO_FORMAT=wav
SPEECH_SAMPLE_RATE=22050
SPEECH_ENABLE_BROWSER_FALLBACK=true

# Reproducible local training
TRAINING_SEED=42
TRAINING_DEVICE=cpu
