APP_ENV=development
APP_NAME=OpenSign Darija
APP_VERSION=0.1.0
APP_SECRET_KEY=change-me-in-local-env

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opensign
POSTGRES_USER=opensign
POSTGRES_PASSWORD=opensign_dev_password
DATABASE_URL=postgresql+psycopg://opensign:opensign_dev_password@postgres:5432/opensign

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=opensign
MINIO_SECRET_KEY=opensign_dev_password
MINIO_SECURE=false
MINIO_PRIVATE_VIDEO_BUCKET=opensign-private-videos
MINIO_PRIVATE_LANDMARK_BUCKET=opensign-private-landmarks
MINIO_THUMBNAIL_BUCKET=opensign-review-thumbnails
MINIO_DATASET_EXPORT_BUCKET=opensign-dataset-exports
MINIO_REFERENCE_ASSET_BUCKET=opensign-reference-assets
DATASET_PRESIGNED_URL_EXPIRE_SECONDS=600
DATASET_MAX_RECORDINGS_PER_CONTRIBUTION=5
DATASET_CLEANUP_DRAFT_DAYS=7

JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

INFERENCE_SERVICE_URL=http://inference:8001
INFERENCE_TIMEOUT_SECONDS=3
ALLOW_SMOKE_MODEL_ACTIVATION=false

VITE_API_BASE_URL=http://localhost:8000
VITE_MEDIAPIPE_MODEL_PATH=https://storage.googleapis.com/mediapipe-models/holistic_landmarker/holistic_landmarker/float16/1/holistic_landmarker.task
VITE_MEDIAPIPE_WASM_PATH=https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.35/wasm
MEDIAPIPE_HOLISTIC_MODEL_PATH=ml/assets/mediapipe/holistic_landmarker.task
MEDIAPIPE_HOLISTIC_MODEL_URL=https://storage.googleapis.com/mediapipe-models/holistic_landmarker/holistic_landmarker/float16/1/holistic_landmarker.task
VITE_CAMERA_DEFAULT_WIDTH=1280
VITE_CAMERA_DEFAULT_HEIGHT=720
VITE_CAMERA_DEFAULT_FPS=30
VITE_LANDMARK_TARGET_FRAMES=60
VITE_ENABLE_LANDMARK_OVERLAY=true
VITE_ENABLE_PERFORMANCE_METRICS=false

RECOGNITION_MAX_FRAMES=60
RECOGNITION_MAX_PAYLOAD_BYTES=1500000
RECOGNITION_MIN_DURATION_MS=500
RECOGNITION_MAX_DURATION_MS=8000
RECOGNITION_RATE_LIMIT=30
FEATURE_SCHEMA_VERSION=1.0.0
NGINX_HOST_PORT=8081

INFERENCE_MODE=mock
ACTIVE_MODEL_ID=
MODEL_NAME=opensign-darija-landmark-mock
MODEL_VERSION=0.2.0
MODEL_PATH=
LABELS_PATH=
THRESHOLDS_PATH=
CALIBRATION_PATH=
MODEL_BUCKET=opensign-model-artifacts
MODEL_CACHE_DIR=/tmp/opensign-model-cache
MODEL_DOWNLOAD_TIMEOUT_SECONDS=10
MODEL_LOAD_TIMEOUT_SECONDS=10
MODEL_WARMUP_ENABLED=true
MODEL_CHECKSUM_REQUIRED=true
MODEL_MAX_SIZE_BYTES=50000000
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider
ONNX_INTRA_OP_THREADS=1
ONNX_INTER_OP_THREADS=1
ONNX_ENABLE_CPU_MEM_ARENA=true
INFERENCE_REQUEST_TIMEOUT_SECONDS=3
INFERENCE_MAX_BATCH_SIZE=1
INFERENCE_MAX_CONCURRENT_REQUESTS=4
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=opensign-darija
TRAINING_SEED=42
TRAINING_DEVICE=cpu

# Development-only MoSL smoke validation example:
# INFERENCE_MODE=real
# FEATURE_SCHEMA_VERSION=OPEN_SIGNE_LANDMARK_SCHEMA_V1
# MODEL_NAME=mosl-word-smoke-v1
# MODEL_VERSION=0.1.0-smoke
# MODEL_PATH=/workspace/artifacts/models/mosl-word-smoke-v1/model.onnx
# LABELS_PATH=/workspace/artifacts/models/mosl-word-smoke-v1/labels.json
# ALLOW_SMOKE_MODEL_ACTIVATION=true

LINGUISTIC_ENGINE_MODE=controlled
LINGUISTIC_ENGINE_VERSION=1.0.0
LINGUISTIC_DICTIONARY_VERSION=demo-1.0.0
LINGUISTIC_TEMPLATE_VERSION=demo-1.0.0
MESSAGE_MAX_ITEMS=30
MESSAGE_MAX_TEXT_LENGTH=1200
MESSAGE_MAX_REVISIONS=80
MESSAGE_AUTOSAVE_DELAY_MS=800
MESSAGE_HISTORY_ENABLED=true
GUEST_MESSAGE_TTL_MINUTES=120
SPEECH_SERVICE_URL=http://speech:8010
SPEECH_MODE=local
SPEECH_PROVIDER=local_darija
SPEECH_MODEL_PATH=
SPEECH_MODEL_BUCKET=opensign-speech-models
SPEECH_MODEL_VERSION=opensign-tone-v1
SPEECH_DEFAULT_VOICE_ID=darija-default
SPEECH_FALLBACK_PROVIDER=local_arabic_fallback
SPEECH_DEVICE=cpu
SPEECH_MAX_TEXT_LENGTH=500
SPEECH_MAX_SENTENCES=5
SPEECH_MAX_CONCURRENT_GENERATIONS=2
SPEECH_GENERATION_TIMEOUT_SECONDS=20
SPEECH_CACHE_TTL_SECONDS=3600
SPEECH_GUEST_AUDIO_TTL_SECONDS=3600
SPEECH_USER_AUDIO_TTL_SECONDS=86400
SPEECH_AUDIO_FORMAT=wav
SPEECH_SAMPLE_RATE=22050
SPEECH_MODEL_CHECKSUM_REQUIRED=false
SPEECH_ENABLE_BROWSER_FALLBACK=true
SPEECH_AUDIO_BUCKET=opensign-speech-audio
SPEECH_SIGNED_URL_TTL_SECONDS=900

KAGGLE_USERNAME=
KAGGLE_KEY=
EXTERNAL_DATA_ROOT=data/raw/external
EXTERNAL_DATA_MAX_ARCHIVE_BYTES=50000000000
EXTERNAL_DATA_MAX_EXTRACTED_BYTES=50000000000
EXTERNAL_DATA_MAX_FILES=200000
EXTERNAL_DATA_ALLOWED_LICENSES=CC0-1.0,CC-BY-4.0,CC-BY-SA-4.0,ODC-BY-1.0
MENDELEY_DATASET_ID=23phgyt3mt
MENDELEY_DATASET_VERSION=1
MENDELEY_DATASET_DOI=10.17632/23phgyt3mt.1
ALPHABET_MODEL_ID=
WORD_MODEL_ID=
ALPHABET_STABLE_FRAMES=8
ALPHABET_STABLE_DURATION_MS=650
ALPHABET_CONFIDENCE_THRESHOLD=0.65
ALPHABET_COOLDOWN_MS=900
